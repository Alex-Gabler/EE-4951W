#include "main.h"
#include <math.h>
#include <string.h>
#include <stdio.h>

// ===================== PINS =====================
#define PIN_CS    GPIO_PIN_4
#define PIN_CS_PORT GPIOA
#define PIN_START  GPIO_PIN_5
#define PIN_START_PORT GPIOA
#define PIN_PWDN   GPIO_PIN_6
#define PIN_PWDN_PORT GPIOA
#define PIN_DRDY   GPIO_PIN_0
#define PIN_DRDY_PORT GPIOB

// ===================== ADS1292 COMMANDS =====================
#define CMD_RESET   0x06
#define CMD_START   0x08
#define CMD_RDATAC  0x10
#define CMD_SDATAC  0x11

// ===================== CONSTANTS =====================
const float VREF = 2.42f;
const float GAIN = 6.0f;
const float FS   = 500.0f;

// ===================== BIQUAD FILTER =====================
typedef struct {
    float b0, b1, b2;
    float a1, a2;
    float x1, x2;
    float y1, y2;
} Biquad;

Biquad bqHP, bqN1, bqN2, bqLP;

// ===================== INTERRUPT SHARED STATE =====================
volatile bool sampleReady = false;
volatile uint8_t raw[3];

// ===================== BPM DETECTION STATE =====================
float bpm_threshold = 0.4f;
float bpm_peak = 0.0f;
float bpm_baseline = 0.0f;
bool bpm_inPeak = false;
int32_t bpm_lastPeakSample = 0;
int32_t bpm_sampleCount = 0;
float bpm_value = 0.0f;
float bpm_rr_avg = 0.0f;

const int32_t BPM_REFRACTORY = 40; // at 100 SPS

// ===================== UART HANDLE =====================
extern UART_HandleTypeDef huart2;

// ===================== ISR =====================
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    if (GPIO_Pin == PIN_DRDY) {
        HAL_GPIO_WritePin(PIN_CS_PORT, PIN_CS, GPIO_PIN_RESET);

        raw[0] = (uint8_t)HAL_SPI_TransmitReceive(&hspi1, (uint8_t[]){0x00}, &raw[0], 1, HAL_MAX_DELAY);
        raw[1] = (uint8_t)HAL_SPI_TransmitReceive(&hspi1, (uint8_t[]){0x00}, &raw[1], 1, HAL_MAX_DELAY);
        raw[2] = (uint8_t)HAL_SPI_TransmitReceive(&hspi1, (uint8_t[]){0x00}, &raw[2], 1, HAL_MAX_DELAY);

        HAL_GPIO_WritePin(PIN_CS_PORT, PIN_CS, GPIO_PIN_SET);

        sampleReady = true;
    }
}

// ===================== BIQUAD FILTER HELPERS =====================
float applyBiquad(Biquad *bq, float x0)
{
    float y0 = bq->b0*x0 + bq->b1*bq->x1 + bq->b2*bq->x2
               - bq->a1*bq->y1 - bq->a2*bq->y2;
    bq->x2 = bq->x1; bq->x1 = x0;
    bq->y2 = bq->y1; bq->y1 = y0;
    return y0;
}

// ===================== CONVERSION =====================
long to24Signed(uint8_t b1, uint8_t b2, uint8_t b3)
{
    long v = ((long)b1<<16) | ((long)b2<<8) | b3;
    if (v & 0x800000L) v |= 0xFF000000L;
    return v;
}

float toMillivolts(long code)
{
    return (float)code * (2.0f * VREF) / (GAIN * 16777216.0f) * 1000.0f;
}

// ===================== BPM DETECTOR =====================
bool detectBPM(float mV)
{
    bpm_sampleCount++;
    bpm_baseline = 0.999f*bpm_baseline + 0.001f*mV;
    float centered = mV - bpm_baseline;

    if (!bpm_inPeak && centered > bpm_threshold) {
        bpm_inPeak = true;
        bpm_peak = centered;
    }

    if (bpm_inPeak) {
        if (centered > bpm_peak) bpm_peak = centered;

        if (centered < bpm_threshold*0.5f) {
            bpm_inPeak = false;
            int32_t rr = bpm_sampleCount - bpm_lastPeakSample;
            if (rr > BPM_REFRACTORY) {
                bpm_lastPeakSample = bpm_sampleCount;
                bpm_rr_avg = bpm_rr_avg == 0.0f ? rr : 0.75f*bpm_rr_avg + 0.25f*rr;
                bpm_value = 6000.0f / bpm_rr_avg;
                bpm_threshold = bpm_peak * 0.5f;
                if (bpm_threshold < 0.05f) bpm_threshold = 0.05f;
                if (bpm_threshold > 2.0f) bpm_threshold = 2.0f;
                bpm_peak = 0.0f;
                return true;
            }
            bpm_peak = 0.0f;
        }
    }
    return false;
}

// ===================== SETUP =====================
void adsInit()
{
    // reset, config registers, filters etc. (same as Arduino code)
    // attach EXTI interrupt on PIN_DRDY
}

// ===================== MAIN LOOP =====================
void adsLoop()
{
    if (sampleReady) {
        uint8_t b1 = raw[0];
        uint8_t b2 = raw[1];
        uint8_t b3 = raw[2];
        sampleReady = false;

        long code = to24Signed(b1,b2,b3);
        float mV = toMillivolts(code);

        // Filter chain
        mV = applyBiquad(&bqHP, mV);
        mV = applyBiquad(&bqN1, mV);
        mV = applyBiquad(&bqN2, mV);
        mV = applyBiquad(&bqLP, mV);

        // Decimate to 100 SPS
        static uint8_t decimator = 0;
        if (++decimator >= 5) {
            decimator = 0;

            // Send ECG mV
            char buf[32];
            sprintf(buf, "%0.4f\r\n", mV);
            HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), HAL_MAX_DELAY);

            // BPM detector
            if (detectBPM(mV)) {
                sprintf(buf, "# BPM = %0.1f\r\n", bpm_value);
                HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), HAL_MAX_DELAY);
            }
        }
    }
}
