/**
 * @file    ads1292r.c
 * @brief   ADS1292R ECG driver — exact STM32 HAL port of the Arduino sketch.
 *
 *  Every function maps 1-to-1 with the Arduino code:
 *
 *  Arduino                          STM32
 *  -------                          ------
 *  SPI.transfer(b)                  spi_xfer(b)
 *  digitalWrite(CS, LOW/HIGH)       cs_low() / cs_high()
 *  delayMicroseconds(n)             delay_us(n)
 *  delay(n)                         HAL_Delay(n)
 *  attachInterrupt(FALLING, isr)    HAL_GPIO_EXTI_Callback + EXTI15_10_IRQHandler
 *  noInterrupts() / interrupts()    __disable_irq() / __enable_irq()
 *  Serial.println(mV, 4)            printf("%.4f\r\n", mV)
 *  PI                               (float)M_PI
 *  static local in loop()           file-scope static
 *
 *  SPI peripheral : hspi2  (SPI2, 8-bit, Mode 1, 4 MHz, NSS soft)
 *  CS pin         : PB12   (reconfigured from AF5 to GPIO_OUTPUT in ADS1292R_Init)
 */

#include "ads1292r.h"
#include <stdio.h>
#include <math.h>

/* ===================== EXTERNAL HANDLE ===================== */
extern SPI_HandleTypeDef hspi2;

/* ===================== CONSTANTS — identical to Arduino sketch ===================== */
#define VREF    2.42f
#define GAIN    6.0f
#define FS      500.0f   /* ADS1292R output data rate; must match CONFIG1 = 0x02 */

/* Decimation: 500 SPS → 100 SPS for the filter output and BPM detector */
#define DECIMATE        5
#define FS_DEC          100.0f

/* Refractory period at 100 SPS (same logic as Arduino BPM_REFRACTORY = 40) */
#define BPM_REFRACTORY  40

/* ===================== BIQUAD FILTER — same struct as Arduino Biquad ===================== */
typedef struct {
    float b0, b1, b2;
    float a1, a2;
    float x1, x2;
    float y1, y2;
} Biquad;

/* ===================== MODULE-LEVEL STATE ===================== */

/* Filter instances — mirrors Arduino globals bqHP, bqN1, bqN2, bqLP */
static Biquad s_bqHP, s_bqN1, s_bqN2, s_bqLP;

/* ISR shared state — mirrors Arduino volatile sampleReady / raw[] */
static volatile uint8_t s_sampleReady = 0;
static volatile uint8_t s_raw[3];

/* BPM detector state — mirrors Arduino bpm_xxx globals */
static float   s_bpm_threshold      = 0.4f;
static float   s_bpm_peak           = 0.0f;
static float   s_bpm_baseline       = 0.0f;
static uint8_t s_bpm_inPeak         = 0;
static int32_t s_bpm_lastPeakSample = 0;
static int32_t s_bpm_sampleCount    = 0;
static float   s_bpm_value          = 0.0f;
static float   s_bpm_rr_avg         = 0.0f;

/* Decimation counter — mirrors Arduino static decimator in loop() */
static uint8_t s_decimator = 0;

/* ===================== SPI / GPIO HELPERS ===================== */

/* Replaces Arduino SPI.transfer(b) */
static inline uint8_t spi_xfer(uint8_t tx)
{
    uint8_t rx = 0;
    HAL_SPI_TransmitReceive(&hspi2, &tx, &rx, 1, HAL_MAX_DELAY);
    return rx;
}

/* Replaces Arduino delayMicroseconds(n) */
static void delay_us(uint32_t us)
{
    volatile uint32_t n = us * 8u;   /* ~1 µs per iteration @ 32 MHz */
    while (n--) { __NOP(); }
}

/* CS pin helpers — replace Arduino PORTB bit-bang */
static inline void cs_low(void)  { HAL_GPIO_WritePin(ADS_CS_GPIO_Port, ADS_CS_Pin, GPIO_PIN_RESET); }
static inline void cs_high(void) { HAL_GPIO_WritePin(ADS_CS_GPIO_Port, ADS_CS_Pin, GPIO_PIN_SET);   }

/* ===================== ADS1292R SPI TRANSACTIONS =====================
 *  Direct ports of adsCommand(), adsRead(), adsWrite() from Arduino sketch.
 */

static void ads_command(uint8_t cmd)
{
    cs_low();
    delay_us(5);
    spi_xfer(cmd);
    delay_us(5);
    cs_high();
    delay_us(20);
}

static uint8_t ads_read_reg(uint8_t reg)
{
    cs_low();
    delay_us(5);
    spi_xfer(0x20 | reg);   /* RREG | address */
    spi_xfer(0x00);         /* read 1 register */
    uint8_t val = spi_xfer(0x00);
    delay_us(5);
    cs_high();
    delay_us(20);
    return val;
}

static void ads_write_reg(uint8_t reg, uint8_t val)
{
    cs_low();
    delay_us(5);
    spi_xfer(0x40 | reg);   /* WREG | address */
    spi_xfer(0x00);         /* write 1 register */
    spi_xfer(val);
    delay_us(5);
    cs_high();
    delay_us(20);
}

/* ===================== FILTER DESIGN — identical to Arduino functions ===================== */

static void designHighPass(Biquad *bq, float fc)
{
    float w = tanf((float)M_PI * fc / FS);
    float k = 1.0f / (1.0f + w);
    bq->b0 =  k;
    bq->b1 = -k;
    bq->b2 =  0.0f;
    bq->a1 =  k * (w - 1.0f);
    bq->a2 =  0.0f;
    bq->x1 = bq->x2 = bq->y1 = bq->y2 = 0.0f;
}

static void designNotch(Biquad *bq, float f0, float r)
{
    float w0 = 2.0f * (float)M_PI * f0 / FS;
    float c  = cosf(w0);
    bq->b0 =  1.0f;
    bq->b1 = -2.0f * c;
    bq->b2 =  1.0f;
    bq->a1 = -2.0f * r * c;
    bq->a2 =  r * r;
    bq->x1 = bq->x2 = bq->y1 = bq->y2 = 0.0f;
}

static void designLowPass(Biquad *bq, float fc)
{
    float w  = tanf((float)M_PI * fc / FS);
    float w2 = w * w;
    float n  = 1.0f / (1.0f + sqrtf(2.0f) * w + w2);
    bq->b0 =  w2 * n;
    bq->b1 =  2.0f * bq->b0;
    bq->b2 =  bq->b0;
    bq->a1 =  2.0f * (w2 - 1.0f) * n;
    bq->a2 =  (1.0f - sqrtf(2.0f) * w + w2) * n;
    bq->x1 = bq->x2 = bq->y1 = bq->y2 = 0.0f;
}

/* Replaces Arduino applyBiquad() */
static float applyBiquad(Biquad *bq, float x0)
{
    float y0 = bq->b0 * x0
             + bq->b1 * bq->x1
             + bq->b2 * bq->x2
             - bq->a1 * bq->y1
             - bq->a2 * bq->y2;
    bq->x2 = bq->x1;  bq->x1 = x0;
    bq->y2 = bq->y1;  bq->y1 = y0;
    return y0;
}

/* ===================== CONVERSION — identical to Arduino ===================== */

/* Replaces Arduino to24Signed() */
static int32_t to24Signed(uint8_t b1, uint8_t b2, uint8_t b3)
{
    int32_t v = ((int32_t)b1 << 16) | ((int32_t)b2 << 8) | b3;
    if (v & 0x800000L) v |= (int32_t)0xFF000000L;
    return v;
}

/* Replaces Arduino toMillivolts() */
static float toMillivolts(int32_t code)
{
    return (float)code * (2.0f * VREF) / (GAIN * 16777216.0f) * 1000.0f;
}

/* ===================== BPM DETECTOR — identical logic to Arduino detectBPM() ===================== */

static uint8_t detectBPM(float mV)
{
    s_bpm_sampleCount++;

    /* Slow baseline tracker ~10 s time constant */
    s_bpm_baseline = 0.999f * s_bpm_baseline + 0.001f * mV;
    float centered = mV - s_bpm_baseline;

    /* Rising edge above threshold → enter peak */
    if (!s_bpm_inPeak && centered > s_bpm_threshold) {
        s_bpm_inPeak = 1;
        s_bpm_peak   = centered;
    }

    if (s_bpm_inPeak) {
        if (centered > s_bpm_peak) s_bpm_peak = centered;

        /* Peak ends when signal falls below half-threshold */
        if (centered < s_bpm_threshold * 0.5f) {
            s_bpm_inPeak = 0;

            int32_t rr = s_bpm_sampleCount - s_bpm_lastPeakSample;

            if (rr > BPM_REFRACTORY) {
                s_bpm_lastPeakSample = s_bpm_sampleCount;

                /* Exponential smoothing of RR interval */
                if (s_bpm_rr_avg == 0.0f)
                    s_bpm_rr_avg = (float)rr;
                else
                    s_bpm_rr_avg = 0.75f * s_bpm_rr_avg + 0.25f * (float)rr;

                /* BPM = FS_DEC * 60 / RR_samples  (same as Arduino: 6000 / rr_avg at 100 SPS) */
                s_bpm_value = (FS_DEC * 60.0f) / s_bpm_rr_avg;

                /* Adaptive threshold: 50% of last peak, clamped 0.05–2.0 */
                s_bpm_threshold = 0.5f * s_bpm_peak;
                if (s_bpm_threshold < 0.05f) s_bpm_threshold = 0.05f;
                if (s_bpm_threshold > 2.0f)  s_bpm_threshold = 2.0f;

                return 1;   /* new BPM available */
            }
            s_bpm_peak = 0.0f;
        }
    }
    return 0;
}

/* ===================== REGISTER VERIFICATION — identical to Arduino verifyRegisters() ===================== */

static void verifyRegisters(void)
{
    static const struct {
        uint8_t     reg;
        const char *name;
        uint8_t     expected;
    } checks[] = {
        { 0x01, "CONFIG1 ", 0x02 },
        { 0x02, "CONFIG2 ", 0xA0 },
        { 0x03, "LOFF    ", 0x10 },
        { 0x04, "CH1SET  ", 0x00 },
        { 0x05, "CH2SET  ", 0x81 },
        { 0x06, "RLD_SENS", 0x23 },
        { 0x07, "LOFF_SN ", 0x00 },
        { 0x09, "RESP1   ", 0x02 },
        { 0x0A, "RESP2   ", 0x07 },
    };

    printf("=== REGISTER VERIFICATION ===\r\n");
    uint8_t allPass = 1;

    for (uint8_t i = 0; i < sizeof(checks)/sizeof(checks[0]); i++) {
        uint8_t actual = ads_read_reg(checks[i].reg);
        uint8_t pass   = (actual == checks[i].expected);
        if (!pass) allPass = 0;
        printf("%s  expected 0x%02X  got 0x%02X  %s\r\n",
               checks[i].name, checks[i].expected, actual,
               pass ? "PASS" : "FAIL");
    }

    printf("\r\n%s\r\n",
           allPass ? "ALL REGISTERS CORRECT — ready for ECG"
                   : "REGISTER MISMATCH — check wiring");
    printf("=============================\r\n\r\n");
}

/* ===================== DRDY ISR — replaces Arduino onDRDY() =====================
 *
 *  Arduino onDRDY() reads 9 bytes with CS driven by PORTB bit-bang.
 *  Here HAL_GPIO_EXTI_Callback is called from EXTI15_10_IRQHandler
 *  (defined in stm32l4xx_it.c).
 *
 *  Frame layout (RDATAC mode):
 *    Bytes 0-2  : status
 *    Bytes 3-5  : CH1 (ECG)
 *    Bytes 6-8  : CH2 (powered down — must still clock out)
 */
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    if (GPIO_Pin != DRDY_Pin)
        return;

    cs_low();

    /* 3 status bytes */
    spi_xfer(0x00);
    spi_xfer(0x00);
    spi_xfer(0x00);

    /* CH1 — 3 bytes */
    s_raw[0] = spi_xfer(0x00);
    s_raw[1] = spi_xfer(0x00);
    s_raw[2] = spi_xfer(0x00);

    /* CH2 — 3 bytes (powered down, clock out to complete the frame) */
    spi_xfer(0x00);
    spi_xfer(0x00);
    spi_xfer(0x00);

    cs_high();
    s_sampleReady = 1;
}

/* ===================== PUBLIC: ADS1292R_Init() — replaces Arduino setup() ===================== */

void ADS1292R_Init(void)
{
    /* Reconfigure PB12 from SPI2_NSS (AF5) to plain push-pull GPIO output.
     * Safe because MX_SPI2_Init uses SPI_NSS_SOFT — the peripheral never
     * drives PB12 on its own. */
    GPIO_InitTypeDef GPIO_InitStruct = {0};
    __HAL_RCC_GPIOB_CLK_ENABLE();
    GPIO_InitStruct.Pin   = ADS_CS_Pin;
    GPIO_InitStruct.Mode  = GPIO_MODE_OUTPUT_PP;
    GPIO_InitStruct.Pull  = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
    HAL_GPIO_Init(ADS_CS_GPIO_Port, &GPIO_InitStruct);

    /* Idle levels — mirrors Arduino pinMode() + digitalWrite() in setup() */
    cs_high();
    HAL_GPIO_WritePin(ADS_START_GPIO_Port, ADS_START_Pin, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(ADS_RESET_GPIO_Port, ADS_RESET_Pin, GPIO_PIN_SET);

    /* Hardware reset pulse — mirrors Arduino PWDN toggle */
    HAL_GPIO_WritePin(ADS_RESET_GPIO_Port, ADS_RESET_Pin, GPIO_PIN_RESET);
    HAL_Delay(10);
    HAL_GPIO_WritePin(ADS_RESET_GPIO_Port, ADS_RESET_Pin, GPIO_PIN_SET);
    HAL_Delay(100);

    /* Software reset + stop continuous mode */
    ads_command(ADS_CMD_RESET);
    HAL_Delay(20);
    ads_command(ADS_CMD_SDATAC);
    HAL_Delay(10);

    /* Chip ID check — mirrors Arduino adsRead(0x00) */
    uint8_t id = ads_read_reg(0x00);
    printf("=== CHIP ID ===\r\n");
    printf("ID = 0x%02X\r\n", id);
    if (id == 0x53 || id == 0x73)
        printf("PASS: ADS1292R detected\r\n\r\n");
    else
        printf("FAIL: unexpected ID (expected 0x53 or 0x73)\r\n\r\n");

    /* Register configuration — identical values to Arduino sketch */
    ads_write_reg(0x01, 0x02);  HAL_Delay(5);    /* CONFIG1: 500 SPS            */
    ads_write_reg(0x02, 0xA0);  HAL_Delay(150);  /* CONFIG2: int ref on         */
    ads_write_reg(0x03, 0x10);  HAL_Delay(5);    /* LOFF: off                   */
    ads_write_reg(0x04, 0x00);  HAL_Delay(5);    /* CH1SET: gain 6x, electrode  */
    ads_write_reg(0x05, 0x81);  HAL_Delay(5);    /* CH2SET: powered down        */
    ads_write_reg(0x06, 0x23);  HAL_Delay(5);    /* RLD_SENS: IN1P+IN1N to RLD  */
    ads_write_reg(0x07, 0x00);  HAL_Delay(5);    /* LOFF_SENS: off              */
    ads_write_reg(0x09, 0x02);  HAL_Delay(5);    /* RESP1: off                  */
    ads_write_reg(0x0A, 0x07);  HAL_Delay(5);    /* RESP2: ADS1292R correction  */

    verifyRegisters();

    /* Filter design — identical parameters to Arduino setup() */
    designHighPass(&s_bqHP, 0.67f);
    designNotch   (&s_bqN1, 60.0f, 0.88f);
    designNotch   (&s_bqN2, 60.0f, 0.96f);
    designLowPass (&s_bqLP, 40.0f);

    /* Start conversions — mirrors Arduino START pin + CMD_START + CMD_RDATAC */
    HAL_GPIO_WritePin(ADS_START_GPIO_Port, ADS_START_Pin, GPIO_PIN_SET);
    HAL_Delay(10);
    ads_command(ADS_CMD_START);
    HAL_Delay(10);
    ads_command(ADS_CMD_RDATAC);
    HAL_Delay(10);

    printf("Ready — ECG_mV printed to UART, # BPM on each beat\r\n");
    printf("ECG_mV\r\n");
}

/* ===================== PUBLIC: ADS1292R_Process() — replaces Arduino loop() ===================== */

void ADS1292R_Process(void)
{
    /* Mirror of Arduino: if (!sampleReady) return */
    if (!s_sampleReady)
        return;

    /* Atomic copy — mirrors Arduino noInterrupts() / interrupts() */
    __disable_irq();
    uint8_t b1 = s_raw[0];
    uint8_t b2 = s_raw[1];
    uint8_t b3 = s_raw[2];
    s_sampleReady = 0;
    __enable_irq();

    /* Convert raw bytes — mirrors Arduino to24Signed + toMillivolts */
    int32_t code = to24Signed(b1, b2, b3);
    float   mV   = toMillivolts(code);

    /* Filter chain — mirrors Arduino applyBiquad calls in loop() */
    mV = applyBiquad(&s_bqHP, mV);
    mV = applyBiquad(&s_bqN1, mV);
    mV = applyBiquad(&s_bqN2, mV);
    mV = applyBiquad(&s_bqLP, mV);

    /* Decimate 500 → 100 SPS — mirrors Arduino: if (++decimator >= 5) */
    if (++s_decimator < DECIMATE)
        return;
    s_decimator = 0;

    /* Print mV — mirrors Arduino Serial.println(mV, 4) */
    printf("%.4f\r\n", mV);

    /* BPM detection — mirrors Arduino detectBPM + Serial.print("# BPM = ") */
    if (detectBPM(mV)) {
        printf("# BPM = %.1f\r\n", s_bpm_value);
        HAL_GPIO_TogglePin(Heartbeat_Led_GPIO_Port, Heartbeat_Led_Pin);
    }
}
